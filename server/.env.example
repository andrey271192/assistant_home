# Copy to server/.env and fill in (never commit .env)

ENV=development
HOST=0.0.0.0
PORT=8010

# Public HTTPS URL for Telegram Mini App (no trailing slash)
# Example on keenetichome VPS: https://keenetichome.ru/ah
# NOT the HA UI: http://xa.homesmart.netcraze.pro:81/home
PUBLIC_BASE_URL=https://keenetichome.ru/ah
# If nginx uses location /ah/ → set for correct OpenAPI/links:
ROOT_PATH=/ah

TELEGRAM_TOKEN=
# Comma-separated Telegram user IDs allowed to use bot/Mini App
TELEGRAM_ALLOWED_IDS=

# PIN for toggles and automations in Mini App (optional empty = disabled)
TELEGRAM_PIN=
TELEGRAM_PIN_SESSION_HOURS=12

# Home Assistant
HA_URL=http://192.168.1.10:8123
HA_TOKEN=
